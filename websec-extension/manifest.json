{
  "manifest_version": 3,
  "name": "WebSec Scanner",
  "version": "2.5.0",
  "description": "Automated website security scanner powered by WebSec Engine V2.5",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8000/*", "https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebSec Scanner",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
